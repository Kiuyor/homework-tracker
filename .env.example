# =============================================
# Vercel Postgres 数据库连接（本地开发用）
# =============================================
# Vercel 部署时自动注入以下环境变量，无需手动设置
# 本地开发时需要从 Vercel Postgres 面板复制连接字符串
#
# 获取方式：
#   1. 在 Vercel 控制台创建 Postgres 数据库
#   2. 在 Storage → Postgres → .env.local 标签页复制
#   3. 粘贴到本地的 .env 文件中
#
# 或者使用本地 PostgreSQL：
#   POSTGRES_URL=postgres://user:password@localhost:5432/homework_tracker

POSTGRES_URL=postgres://default:xxxxx@ep-example-123456.us-east-1.aws.neon.tech/homework_tracker?sslmode=require
POSTGRES_PRISMA_URL=postgres://default:xxxxx@ep-example-123456.us-east-1.aws.neon.tech/homework_tracker?sslmode=require&pgbouncer=true
POSTGRES_URL_NON_POOLING=postgres://default:xxxxx@ep-example-123456.us-east-1.aws.neon.tech/homework_tracker?sslmode=require
POSTGRES_USER=default
POSTGRES_HOST=ep-example-123456.us-east-1.aws.neon.tech
POSTGRES_PASSWORD=xxxxx
POSTGRES_DATABASE=homework_tracker
